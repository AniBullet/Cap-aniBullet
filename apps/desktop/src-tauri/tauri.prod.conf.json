{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Cap-aniBullet",
	"mainBinaryName": "Cap-aniBullet",
	"identifier": "so.cap.desktop.anibullet",
	"build": {
		"beforeBundleCommand": "node scripts/prodBeforeBundle.js"
	},
	"plugins": {
		"updater": {
			"active": false,
			"pubkey": ""
		}
	},
	"bundle": {
		"createUpdaterArtifacts": false,
		"shortDescription": "Local-first screen recording & editing",
		"macOS": {
			"entitlements": "Entitlements.plist"
		},
		"windows": {
			"nsis": {
				"installMode": "currentUser",
				"installerHooks": "nsis-hooks.nsh",
				"languages": ["English", "SimpChinese"],
				"customLanguageFiles": {
					"English": "nsis-lang-en.nsh",
					"SimpChinese": "nsis-lang-zh.nsh"
				}
			}
		}
	}
}
